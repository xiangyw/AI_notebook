# ===========================================
# Notebook Application Environment Variables
# ===========================================

# -------------------------------------------
# Application Settings
# -------------------------------------------
NODE_ENV=development
PORT=3000

# -------------------------------------------
# MySQL Database Configuration
# -------------------------------------------
MYSQL_ROOT_PASSWORD=NotebookRoot2026!
MYSQL_PASSWORD=Notebook2026!
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_NAME=notebook
DATABASE_USER=notebook

# -------------------------------------------
# Data Directory (inside container)
# -------------------------------------------
DATA_DIR=/app/server/data

# -------------------------------------------
# JWT Secret (for future auth)
# -------------------------------------------
JWT_SECRET=your-secret-key-change-in-production

# -------------------------------------------
# Docker Volume Base Path (Host)
# -------------------------------------------
DOCKER_VOLUME_BASE=/home/ubuntu-user/docker
